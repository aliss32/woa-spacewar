<?xml version="1.0" encoding="utf-8"?>
<!--
  Spacewar (Nothing Phone 1) Windows Driver Definitions
  SoC: Qualcomm Snapdragon 778G+ (SM7325-AE)
  GPU: Adreno 642L (a660)
  Base: Lisa (SM7325) GPU + A52s (SM7325) Platform + Spacewar native firmware
-->
<Packages>

  <!-- ============ PLATFORM DRIVERS (Generic SM7325) ============ -->

  <!-- Bluetooth: QCA6750 -->
  <Package Id="Platform.Bluetooth" SourceDirectory="Platform\BTFMUART_HSP" />

  <!-- Wi-Fi: QCA6750 WLAN -->
  <Package Id="Platform.WLAN" SourceDirectory="Platform\Drivers\WLAN" />

  <!-- Cellular Modem -->
  <Package Id="Platform.Cellular" SourceDirectory="Platform\Drivers\Cellular" />

  <!-- Audio (Platform) -->
  <Package Id="Platform.Audio" SourceDirectory="Platform\Drivers\Audio" />

  <!-- USB (Platform) -->
  <Package Id="Platform.USB" SourceDirectory="Platform\Drivers\USB" />
  <Package Id="Platform.USBFn" SourceDirectory="Platform\Drivers\USBFn" />
  <Package Id="Platform.USBHost" SourceDirectory="Platform\Drivers\USBHost" />

  <!-- ============ GPU DRIVER (Adreno 642L native) ============ -->
  <Package Id="Graphics.GPU.Adreno642L" SourceDirectory="components\QC7325\Graphics\GRAPHICS.SOC_QC7325.SPACEWAR_DESKTOP" />

  <!-- ============ DEVICE-SPECIFIC DRIVERS (Nothing Phone 1) ============ -->

  <!-- Haptics -->
  <Package Id="Device.Haptics" SourceDirectory="Drivers\Haptics" />

  <!-- Audio (Device Specific) -->
  <Package Id="Device.Audio" SourceDirectory="Drivers\Audio" />

  <!-- PMIC (Native Qualcomm) -->
  <Package Id="Device.PMIC" SourceDirectory="Drivers\QcPmic" />

  <!-- Touch -->
  <Package Id="Device.Touch" SourceDirectory="Drivers\Touch" />

</Packages>
