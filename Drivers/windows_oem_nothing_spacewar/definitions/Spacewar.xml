<?xml version="1.0" encoding="utf-8"?>
<!--
  Spacewar (Nothing Phone 1) Windows Driver Definitions
  SoC: Qualcomm Snapdragon 778G+ (SM7325-AE)
  GPU: Adreno 642L (a660)
  Base: Lisa (SM7325) GPU + A52s (SM7325) Platform + Spacewar native firmware
-->
<Packages>

  <!-- ============ PLATFORM DRIVERS (Generic SM7325) ============ -->

  <!-- Bluetooth: QCA6750 (same across all SM7325 devices) -->
  <Package Id="Platform.Bluetooth" SourceDirectory="Platform\Drivers\Bluetooth" />

  <!-- Wi-Fi: QCA6750 WLAN -->
  <Package Id="Platform.WLAN" SourceDirectory="Platform\Drivers\WLAN" />

  <!-- Cellular Modem -->
  <Package Id="Platform.Cellular" SourceDirectory="Platform\Drivers\Cellular" />

  <!-- ============ GPU DRIVER (Adreno 642L native) ============ -->
  <!--
    This package combines:
    - Lisa QC7325 GPU userspace DLLs (qcdx, OpenCL, Vulkan, CB, libgsluser)
    - Spacewar-native GPU microcode: a660_sqe.fw (Adreno 642L GFX firmware)
    - qcvss6490.mbn                  (GPU Video Subsystem microcode)
    The INF (qcdx6490.inf) supports 49 Snapdragon device sections,
    covering VEN_QCOM DEV_0E36 and related SM7325 ACPI hardware IDs.
  -->
  <Package Id="Graphics.GPU.Adreno642L" SourceDirectory="components\QC7325\Graphics\GRAPHICS.SOC_QC7325.SPACEWAR_DESKTOP" />

  <!-- ============ DEVICE-SPECIFIC DRIVERS (Nothing Phone 1) ============ -->

  <!-- Battery / Charging: Nothing Phone 1 uses Qualcomm PMIC + BMS -->
  <Package Id="Device.Battery" SourceDirectory="Drivers\Battery" />

  <!-- Haptics: Nothing Phone 1 vibration motor -->
  <Package Id="Device.Haptics" SourceDirectory="Drivers\Haptics" />

  <!-- PMIC (SM5714 is A52s specific; Spacewar uses PM7325 but shares many interfaces) -->
  <Package Id="Device.PMIC" SourceDirectory="Drivers\SM5714Pmic" />

  <!-- Touch: Capacitive touchscreen (post-boot calibration TBD) -->
  <Package Id="Device.Touch" SourceDirectory="Drivers\Touch" />

</Packages>
